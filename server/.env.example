# ZSMART OSS Backend — Environment Configuration
# Copy this file to ".env" and fill in real values.

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL connection string (Prisma reads DATABASE_URL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zsmart_oss?schema=public"

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h
